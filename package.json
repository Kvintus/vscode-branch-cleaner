{
  "name": "vscode-branch-cleaner",
  "displayName": "Branch Cleaner",
  "description": "Git Cleaner–style local branch review in VS Code: list cleanup candidates, see merged / not merged vs your default branch from origin, and inspect them in one place—powered by the built-in Git extension.",
  "version": "0.1.4",
  "publisher": "Kvintus",
  "repository": {
    "type": "git",
    "url": "https://github.com/momentum/vscode-branch-cleaner.git"
  },
  "license": "MIT",
  "icon": "media/branch-cleaner.png",
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [
    "onCommand:branchCleaner.cleanupBranches",
    "workspaceContains:**/.git"
  ],
  "contributes": {
    "commands": [
      {
        "command": "branchCleaner.cleanupBranches",
        "title": "Cleanup Branches",
        "category": "Git"
      }
    ]
  },
  "scripts": {
    "test": "npm run test:unit",
    "verify": "npm run compile && npm run test:unit",
    "check-types": "tsc --noEmit",
    "test:unit": "vitest run --config vitest.config.mts",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "vscode:prepublish": "npm run package",
    "package": "npm run check-types && node esbuild.js --production",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release:marketplace": "npm run test:unit && npx vsce publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/vscode": "~1.96.0",
    "@vscode/vsce": "3.7.1",
    "esbuild": "0.28.0",
    "npm-run-all": "^4.1.5",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  }
}
